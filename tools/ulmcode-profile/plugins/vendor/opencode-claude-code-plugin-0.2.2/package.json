{
  "name": "@khalilgharbaoui/opencode-claude-code-plugin",
  "version": "0.2.2",
  "description": "Claude Code CLI provider plugin for opencode",
  "author": "Khalil Gharbaoui",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test-bridge.ts"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^3.0.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "opencode",
    "claude",
    "claude-code",
    "ai-sdk",
    "provider"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khalilgharbaoui/opencode-claude-code-plugin.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
