{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": false
  },
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000
  },
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high",
      "reasoningEffort": "high",
      "temperature": 0.08,
      "textVerbosity": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5-fast",
          "variant": "xhigh",
          "reasoningEffort": "xhigh",
          "temperature": 0.03
        },
        {
          "model": "opencode-go/glm-5.1",
          "temperature": 0.12
        }
      ],
      "permission": {
        "task": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "external_directory": "ask"
      }
    }
  },
  "categories": {
    "quick": {
      "model": "openai/gpt-5.4-mini-fast",
      "temperature": 0,
      "textVerbosity": "low",
      "description": "Small low-risk fixes, command help, and concise explanations."
    },
    "repo-scout": {
      "model": "openai/gpt-5.4-mini-fast",
      "temperature": 0,
      "textVerbosity": "medium",
      "description": "Read-only repository and target-surface mapping."
    },
    "docs-librarian": {
      "model": "openai/gpt-5.4-mini-fast",
      "temperature": 0,
      "textVerbosity": "medium",
      "description": "Documentation, setup-note, command, API, and convention extraction."
    },
    "pentest-control": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high",
      "reasoningEffort": "high",
      "temperature": 0.08,
      "textVerbosity": "medium",
      "description": "Operation planning, scope control, task routing, and final handoff ownership."
    },
    "recon": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "medium",
      "temperature": 0,
      "textVerbosity": "medium",
      "description": "Reconnaissance, inventory, passive discovery, and low-risk enumeration."
    },
    "evidence": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "medium",
      "temperature": 0,
      "textVerbosity": "medium",
      "description": "Evidence normalization, artifact summarization, and source-to-finding traceability."
    },
    "validator": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh",
      "reasoningEffort": "xhigh",
      "temperature": 0.03,
      "textVerbosity": "medium",
      "description": "High-confidence validation, exploit reproducibility review, and false-positive reduction."
    },
    "report-writer": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high",
      "reasoningEffort": "high",
      "temperature": 0.08,
      "textVerbosity": "medium",
      "description": "Dense report drafting, finding synthesis, artifact handoff, and final readiness checks."
    },
    "verification-court": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high",
      "reasoningEffort": "high",
      "temperature": 0.03,
      "textVerbosity": "medium",
      "description": "Final technical review for bugs, false confidence, missing evidence, and bad handoff claims."
    },
    "xhigh-court": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh",
      "reasoningEffort": "xhigh",
      "temperature": 0.03,
      "textVerbosity": "medium",
      "description": "Emergency review lane for high-risk security, auth, evidence, or architecture failures."
    }
  }
}
