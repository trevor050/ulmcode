{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.4-mini-fast",
  "default_agent": "pentest",
  "skills": {
    "paths": [
      "__ULMCODE_PROFILE_DIR__/skills/pentest-compact"
    ]
  },
  "agent": {
    "pentest": {
      "model": "openai/gpt-5.5-fast",
      "mode": "primary",
      "options": {
        "reasoning_effort": "high"
      }
    },
    "recon": {
      "model": "openai/gpt-5.4-mini-fast",
      "mode": "subagent",
      "options": {
        "reasoning_effort": "medium"
      }
    },
    "evidence": {
      "model": "openai/gpt-5.4-mini-fast",
      "mode": "subagent",
      "options": {
        "reasoning_effort": "medium"
      }
    },
    "validator": {
      "model": "openai/gpt-5.5-fast",
      "mode": "subagent",
      "options": {
        "reasoning_effort": "xhigh"
      }
    },
    "report-writer": {
      "model": "openai/gpt-5.5-fast",
      "mode": "subagent",
      "options": {
        "reasoning_effort": "high"
      }
    }
  },
  "permission": {
    "*": "allow",
    "question": "allow",
    "task": "allow",
    "todowrite": "allow",
    "skill": {
      "*": "deny",
      "k12-agent-orchestration-and-quality": "allow",
      "k12-engagement-safety-and-change-control": "allow",
      "k12-identity-and-privilege-escalation": "allow",
      "k12-recon-and-infrastructure-testing": "allow",
      "k12-risk-mapping-and-reporting": "allow"
    }
  },
  "plugin": [
    "@khalilgharbaoui/opencode-claude-code-plugin",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "pentestMCP": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "ramgameer/pentest-mcp:latest"
      ]
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://192.168.1.151:1234/v1"
      },
      "models": {
        "qwen3.6-28b-reap-i1": {
          "name": "Qwen 28B"
        },
        "qwopus3.6-27b-v1-preview-i1": {
          "name": "Qwopus 27B"
        }
      }
    }
  }
}
